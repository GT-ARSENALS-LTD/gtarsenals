# GT Arsenals Ltd — Backend Environment Variables
# Copy this file and rename it to: .env
# NEVER commit .env to GitHub — it contains passwords!

# ── SMTP EMAIL SETTINGS ─────────────────────────────────────────
# For Zoho Mail (recommended for Nigerian businesses):
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true

# For Gmail (use App Password, not your real Gmail password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

SMTP_USER=info@gtarsenals.com
SMTP_PASS=your_email_password_here

# ── EMAIL ADDRESSES ─────────────────────────────────────────────
TO_EMAIL=info@gtarsenals.com
FROM_EMAIL=info@gtarsenals.com

# ── SERVER ──────────────────────────────────────────────────────
PORT=3001
